{
  "name": "team-dash-backend",
  "version": "1.0.0",
  "description": "Weekly Report Generator & Team Dashboard API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx src/config/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "psql -U postgres -d team_dash -f migrations/001_initial_schema.sql"
  },
